# Copy this file to `.env` and fill in the keys for the providers you use.
# ragbench loads `.env` from the current working directory on `run`.
# Values already exported in the shell take precedence over `.env`.

# Required when system.adapter_config.llm_provider is "anthropic"
# (or when llm_model starts with "claude-")
ANTHROPIC_API_KEY=

# Required when system.adapter_config.llm_provider is "openai"
# (or when llm_model starts with "gpt-", "o1", "o3", "o4")
OPENAI_API_KEY=
